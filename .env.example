# API Base URL (required in production)
VITE_API_BASE_URL=http://localhost:8000

# Optional local-only admin login bypass (frontend dev only)
# WARNING: Keep this disabled in production/staging environments.
VITE_ENABLE_DEV_ADMIN_BYPASS=false
VITE_DEV_ADMIN_EMAIL=admin@aajao.test
VITE_DEV_ADMIN_PASSWORD=Admin@12345
VITE_DISABLE_ADMIN_AUTH=false

# Staging integration runner
STAGING_API_BASE_URL=http://localhost:8000
STAGING_BEARER_TOKEN=

# Optional test IDs for detail and write-path checks
FINANCE_TEST_HOST_ID=
FINANCE_TEST_USER_ID=
FINANCE_TEST_LEDGER_ID=
FINANCE_TEST_PAYOUT_ID=
FINANCE_TEST_INVOICE_ID=
FINANCE_TEST_RECON_ID=
FINANCE_TEST_SCHEDULE_ID=
